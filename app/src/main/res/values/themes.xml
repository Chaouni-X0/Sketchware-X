<resources>
    <style name="Base.Theme.SketchwareX" parent="Scheme.SketchwareX.DayNight" />
    <style name="Theme.SketchwareX" parent="Platform.Theme.SketchwareX">
        <item name="bottomNavigationStyle">@style/Widget.SketchwareX.BottomNavigationView</item>
        <item name="chipStyle">@style/Widget.SketchwareX.Chip</item>
        <item name="collapsingToolbarLayoutStyle">?attr/collapsingToolbarLayoutLargeStyle</item>
        <item name="collapsingToolbarLayoutLargeSize">@dimen/collapsing_toolbar_large_size</item>
        <item name="collapsingToolbarLayoutLargeStyle">@style/Widget.SketchwareX.CollapsingToolbar</item>
        <item name="homeAsUpIndicator">@drawable/abc_ic_ab_back_material</item>
        <item name="textInputStyle">@style/Widget.SketchwareX.TextInputLayout</item>
        <item name="switchPreferenceCompatStyle">
            @style/Preference.SketchwareX.SwitchPreferenceCompat
        </item>
        <item name="tabStyle">@style/Widget.SketchwareX.TabLayout</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.SketchwareX.AlertDialog</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.SketchwareX.AlertDialog</item>
        <item name="popupMenuStyle">@style/Widget.Material3.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.Material3.PopupMenu</item>
        <item name="materialCardViewStyle">?attr/materialCardViewFilledStyle</item>
        <item name="materialCardViewFilledStyle">@style/Widget.SketchwareX.CardView</item>
        <!-- Type styles. -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.SketchwareX.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.SketchwareX.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.SketchwareX.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.SketchwareX.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.SketchwareX.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.SketchwareX.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.SketchwareX.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.SketchwareX.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.SketchwareX.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.SketchwareX.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.SketchwareX.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.SketchwareX.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.SketchwareX.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.SketchwareX.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.SketchwareX.LabelSmall</item>
        <item name="textAppearanceBodyLargeEmphasized">@style/TextAppearance.SketchwareX.BodyLargeEmphasized</item>
    </style>

    <style name="Theme.SketchwareX.Main">
        <item name="navigationViewStyle">@style/Widget.SketchwareX.NavigationView.Main</item>
    </style>

    <style name="Theme.SketchwareX.ProjectPreview">
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.SketchwareX.BottomSheetDialog
        </item>
    </style>

    <style name="Theme.SketchwareX.SmallToolbar">
        <item name="actionBarSize">@dimen/mtrl_toolbar_default_height</item>
        <item name="toolbarStyle">@style/Widget.SketchwareX.Toolbar.SmallText</item>
    </style>

    <style name="Theme.SketchwareX.Starting.Base" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimationDuration">850</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="windowSplashScreenBackground">#000000</item>
        <item name="postSplashScreenTheme">@style/Theme.SketchwareX.Main</item>

        <item name="android:navigationBarColor">@color/splash_bg_color</item>
        <item name="android:statusBarColor">@color/splash_bg_color</item>
        <item name="android:windowLightStatusBar">@bool/is_light_theme</item>
        <item name="android:windowLightNavigationBar">@bool/is_light_theme
        </item>
    </style>

    <style name="Theme.SketchwareX.Starting" parent="Theme.SketchwareX.Starting.Base" />

    <style name="Platform.V21.Theme.SketchwareX" parent="Base.Theme.SketchwareX">
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:statusBarColor">#000000</item>
    </style>
    <style name="Platform.Theme.SketchwareX" parent="Platform.V21.Theme.SketchwareX" />
</resources>
